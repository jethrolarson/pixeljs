rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isModerator() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/config/site) &&
        request.auth.uid in get(/databases/$(database)/documents/config/site).data.moderatorUids;
    }

    match /levels/{levelId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    match /packs/{packId} {
      allow read: if resource.data.published == true
                  || (request.auth != null && request.auth.uid == resource.data.ownerId)
                  || isModerator();
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerId ||
        // moderators can set featured/featuredOrder only
        (isModerator() && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['featured', 'featuredOrder', 'updatedAt']))
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.ownerId || isModerator()
      );

      match /upvotes/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /config/site {
      allow read: if true;
      allow write: if isModerator();
    }
  }
}
